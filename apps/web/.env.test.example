# GitHub Actions local Supabase QA.
# The workflow generates passwords at runtime; do not commit real values.
QA_SUPABASE_URL=http://127.0.0.1:54321
QA_SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
QA_DB_URL=postgresql://postgres:replace-with-local-password@127.0.0.1:54322/postgres
QA_TENANT_A_PASSWORD=generated-at-runtime
QA_TENANT_B_PASSWORD=generated-at-runtime
QA_NO_TENANT_PASSWORD=generated-at-runtime
QA_PROJECT_B_ID=generated-by-seed

# Local privileged key used only when running scripts/backfill-timeline.ts.
SUPABASE_TIMELINE_BACKFILL_KEY=replace-with-local-admin-key
