NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Existing test users provisioned in Supabase Auth.
# They must use the regular publishable key and RLS policies, never a service_role key.
PEOPLE_TEST_TENANT_A_EMAIL=tenant-a-owner@example.com
PEOPLE_TEST_TENANT_A_PASSWORD=replace-with-local-password
PEOPLE_TEST_TENANT_B_EMAIL=tenant-b-owner@example.com
PEOPLE_TEST_TENANT_B_PASSWORD=replace-with-local-password
PEOPLE_TEST_NO_TENANT_EMAIL=no-tenant@example.com
PEOPLE_TEST_NO_TENANT_PASSWORD=replace-with-local-password

# Local app URL for E2E.
PEOPLE_E2E_BASE_URL=http://127.0.0.1:3000
